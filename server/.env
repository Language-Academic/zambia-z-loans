# ==============================================================================
# ZAMBIA Z DIGITAL - HARDENED PRODUCTION CONFIGURATION
# ==============================================================================

# --- Infrastructure ---
PORT=5000
NODE_ENV=production
API_VERSION=v1
APP_URL=https://api.zambiaz.com
FRONTEND_URL=https://zambiaz.com

# --- Database (MongoDB Atlas) ---
# Tip: Use a dedicated DB user with only 'readWrite' permissions for production
DATABASE_URL=mongodb+srv://<db_user>:<secure_password>@cluster.mongodb.net/zambiaz_prod?retryWrites=true&w=majority

# --- Security & Cryptography ---
# Generate 64-character strings: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=0f2d8c3e4b... # DO NOT USE qwertyuiop
JWT_REFRESH_SECRET=a1b2c3d4e5...
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ENCRYPTION_KEY=... # For sensitive data like National IDs

# --- M-PESA (Daraja API) ---
# Regional Switch: Ensure you use the KES vs ZMW logic in your controllers
MPESA_ENVIRONMENT=live
MPESA_CONSUMER_KEY=your_live_key
MPESA_CONSUMER_SECRET=your_live_secret
MPESA_SHORTCODE=your_business_shortcode
MPESA_PASSKEY=your_live_passkey
MPESA_CALLBACK_URL=https://api.zambiaz.com/api/v1/payments/callback

# --- Flutterwave (Cross-Border Payments) ---
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_LIVE-...
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE-...
FLUTTERWAVE_ENCRYPTION_KEY=...
FLUTTERWAVE_WEBHOOK_HASH=zambia_z_secure_hash_2026

# --- Email (SMTP - Transactional) ---
# Professional apps use SendGrid, Postmark, or Amazon SES
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=no-reply@zambiaz.com
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Initial System Access ---
# Use these ONLY for the first seed. Delete from .env after system is live.
SUPER_ADMIN_EMAIL=admin@zambiaz.com
SUPER_ADMIN_PASSWORD=...
