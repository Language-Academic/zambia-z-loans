// This is your professional Zambia Z Prisma schema
// Use 'npx prisma generate' after saving

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS for Type Safety ---
// Prevents spelling errors in status strings

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum LoanStatus {
  PENDING
  VERIFICATION
  APPROVED
  REJECTED
  ACTIVE
  CLOSED
  DEFAULTED
}

enum DisbursementStatus {
  IDLE
  PROCESSING
  COMPLETED
  FAILED
}

enum RepaymentStatus {
  UNPAID
  PARTIAL
  FULL
  OVERDUE
}

enum TransactionType {
  LOAN_FEE
  DISBURSEMENT
  REPAYMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

// --- MODELS ---

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String    // Store Argon2 hashes only[cite: 1]
  fullName           String
  nationalId         String    @unique
  isCitizen          Boolean   @default(true)
  role               Role      @default(USER)
  
  // Financial Profile
  creditScore        Int       @default(400) // Realistic starting score
  loanLimit          Float     @default(1000) // Lower initial limit for risk management
  isActive           Boolean   @default(true)
  
  // Audit Stats
  totalLoansApplied  Int       @default(0)
  totalLoansApproved Int       @default(0)
  lastLogin          DateTime?
  
  // Relations
  loans              Loan[]    @relation("UserLoans")
  adminApprovals     Loan[]    @relation("AdminApprovals")
  notifications      Notification[]
  transactions       Transaction[]
  refreshTokens      RefreshToken[]

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("users")
}

model Loan {
  id                   String             @id @default(uuid())
  userId               String
  user                 User               @relation("UserLoans", fields: [userId], references: [id])
  
  // Financial Data
  principalAmount      Float
  interestRate         Float              @default(15.0)
  serviceFee           Float              @default(0.0)
  penaltyAmount        Float              @default(0.0)
  totalRepaid          Float              @default(0.0)
  
  // Lifecycle Status
  status               LoanStatus         @default(PENDING)
  repaymentStatus      RepaymentStatus    @default(UNPAID)
  
  // Fee/Disbursement Tracking
  feePaid              Boolean            @default(false)
  mpesaFeeRef          String?            @unique
  
  disbursementStatus   DisbursementStatus @default(IDLE)
  disbursementRef      String?            @unique
  disbursedAt          DateTime?
  
  // Approval Logic
  isAutoApproved       Boolean            @default(false)
  approvedByAdminId    String?
  approvedByAdmin      User?              @relation("AdminApprovals", fields: [approvedByAdminId], references: [id])
  rejectionReason      String?
  
  dueDate              DateTime?
  fullyPaidAt          DateTime?
  
  notifications        Notification[]
  transactions         Transaction[]

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([userId, status])
  @@map("loans")
}

model Transaction {
  id                 String            @id @default(uuid())
  userId             String
  user               User              @relation(fields: [userId], references: [id])
  loanId             String?
  loan               Loan?             @relation(fields: [loanId], references: [id])
  
  amount             Float
  type               TransactionType
  status             TransactionStatus @default(PENDING)
  
  // M-Pesa Specific Tracking
  mpesaReceiptNumber String?           @unique
  merchantRequestId  String?           @unique
  checkoutRequestId  String?           @unique
  phoneNumber        String?
  
  description        String?
  createdAt          DateTime          @default(now())

  @@map("transactions")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loanId      String?
  loan        Loan?    @relation(fields: [loanId], references: [id])
  
  title       String
  body        String
  isRead      Boolean  @default(false)
  metadata    Json?    // For deep-linking in Flutter

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("notifications")
}

model RefreshToken {
  id          String   @id @default(uuid())
  token       String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  revoked     Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@map("refresh_tokens")
}
