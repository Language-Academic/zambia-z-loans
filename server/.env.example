# ==============================================================================
# ZAMBIA Z DIGITAL - PRODUCTION CONFIGURATION
# ==============================================================================

# --- Infrastructure ---
PORT=5000
NODE_ENV=production
# The base URL of your deployed API for callbacks and redirects
APP_URL=https://api.zambiaz.com

# --- Database (MongoDB Atlas) ---
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>
# Ensure the password is URL-encoded if it contains special characters.
DATABASE_URL=mongodb+srv://admin_user:YourSecurePassword123@quickloan.ownvxer.mongodb.net/zambiaz_prod?retryWrites=true&w=majority

# --- Security & Authentication ---
# Generate a 64-character secret using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=0f2d8c3e4b5a69781c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b
JWT_REFRESH_SECRET=a1b2c3d4e5f67890a1b2c3d4e5f67890a1b2c3d4e5f67890a1b2c3d4e5f67890

# --- M-PESA (Daraja API) ---
MPESA_ENVIRONMENT=live
MPESA_CONSUMER_KEY=your_live_consumer_key
MPESA_CONSUMER_SECRET=your_live_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# Use your actual production domain for the callback
MPESA_CALLBACK_URL=https://api.zambiaz.com/api/v1/payments/callback

# --- Flutterwave (Optional Cross-Border Fallback) ---
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE-xxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_WEBHOOK_HASH=zambia_z_secure_v3_2026
