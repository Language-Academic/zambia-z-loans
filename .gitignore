# ==========================================
# 1. SYSTEM & DEPENDENCIES
# ==========================================
node_modules/
dist/
build/
.npm
.cache
package-lock.json
# Note: Some teams keep package-lock.json, but in a moving dev environment,
# ignoring it can prevent merge conflicts. For strict production, remove this line.

# ==========================================
# 2. ENVIRONMENT & SECRETS (CRITICAL)
# ==========================================
# Never commit your M-Pesa, PesaPal, or Admin credentials
.env
.env.*
!.env.example
server/.env

# ==========================================
# 3. PRISMA & DATABASE
# ==========================================
# Ignore the local SQLite dev database if you ever switch from MongoDB
*.db
*.db-journal
# If you use Prisma locally, ignore generated files that should be built on the server
/prisma/generated-client

# ==========================================
# 4. LOGS & RUNTIME
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid
*.seed
*.pid.lock

# ==========================================
# 5. TESTING & COVERAGE
# ==========================================
coverage/
.nyc_output
.jest/

# ==========================================
# 6. IDE & OS SPECIFIC
# ==========================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ==========================================
# 7. TEMPORARY FILES
# ==========================================
tmp/
temp/
