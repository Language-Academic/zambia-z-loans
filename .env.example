# ==========================================
# 1. APPLICATION CORE
# ==========================================
NODE_ENV=development
PORT=5000
APP_NAME="Zambia Z Digital"
FRONTEND_URL=https://zambiaz.com
API_BASE_URL=https://api.zambiaz.com

# ==========================================
# 2. DATABASE (PRISMA & MONGODB)
# ==========================================
# Use zambia_z_digital for clear database separation
DATABASE_URL=mongodb://localhost:27017/zambia_z_digital

# ==========================================
# 3. SECURITY & AUTHENTICATION
# ==========================================
# Generate 64-char hex keys for production
JWT_ACCESS_SECRET=your_secure_32_char_access_secret_here
JWT_REFRESH_SECRET=your_secure_32_char_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# 4. PAYMENT GATEWAY: PESAPAL V3
# ==========================================
PESAPAL_ENVIRONMENT=sandbox
PESAPAL_CONSUMER_KEY=your_pesapal_consumer_key
PESAPAL_CONSUMER_SECRET=your_pesapal_consumer_secret
# The IPN ID is generated via the PesaPal API to handle payment notifications
PESAPAL_IPN_ID=your_pesapal_ipn_id
PESAPAL_CALLBACK_URL=https://api.zambiaz.com/api/v1/payments/pesapal-callback

# ==========================================
# 5. NOTIFICATION SERVICE (SMTP)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMAIL_FROM="Zambia Z Support <support@zambiaz.com>"

# ==========================================
# 6. SYSTEM INITIALIZATION (SUPER ADMIN)
# ==========================================
# Credentials for seedSuperAdmin.js
SUPER_ADMIN_EMAIL=mwakidenis2006@gmail.com
SUPER_ADMIN_PASSWORD=Makew@5824
