# ZAMBIA Z - Environment Template
# Instructions: Copy this file to '.env' and fill in the values.

# The base URL for the Zambia Z Backend API (e.g., http://localhost:5000/api/v1)
VITE_API_URL=

# Real-time updates server
VITE_SOCKET_URL=

# Application Name & Environment
VITE_APP_NAME="Zambia Z"
VITE_APP_ENV=development

# Toggles (true/false)
VITE_ENABLE_NOTIFICATIONS=
VITE_MAINTENANCE_MODE=
